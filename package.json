{
  "name": "redpill-app",
  "version": "0.4.1",
  "type": "module",
  "description": "RedPill Desktop Application",
  "keywords": [
    "ipfs",
    "react",
    "redux",
    "web3"
  ],
  "license": "MIT",
  "private": true,
  "scripts": {
    "db:sync": "npx tsx dbSync/syncHistory.ts",
    "db:server": "npx tsx dbSync/server.ts",
    "dev": "vite",
    "build": "vite build",
    "build:dist-package": "node scripts/build-dist-package.js",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "clean:all": "npm run clean && node electron/clean.js",
    "format": "prettier --write \"{src,dbSync,electron}/**/*.{js,ts,tsx}\" \"docs/**/*.md\"",
    "lint": "eslint src dbSync electron",
    "lint:fix": "eslint src dbSync electron --fix",
    "type-check": "tsc --noEmit",
    "build:app-mac-arm64": "node electron/build-platform.js mac-arm64",
    "build:app-mac-x64": "node electron/build-platform.js mac-x64",
    "build:app-win-x64": "node electron/build-platform.js win-x64",
    "build:app-linux-x64": "node electron/build-platform.js linux-x64",
    "verify:app": "node electron/verify-package.js"
  },
  "dependencies": {
    "@filoz/synapse-sdk": "^0.40.0",
    "@glif/filecoin-address": "^4.0.0",
    "@heroicons/react": "^2.2.0",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/peer-id": "^6.0.4",
    "@noble/hashes": "^2.0.1",
    "@secured-finance/stablecoin-lib-base": "^1.1.0",
    "@secured-finance/stablecoin-lib-ethers": "^1.1.1",
    "@types/use-sync-external-store": "^0.0.6",
    "@vitejs/plugin-react": "^5.1.2",
    "boring-avatars": "^2.0.4",
    "buffer": "^6.0.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.7.4",
    "jszip": "^3.10.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^16.5.3",
    "react-redux": "^9.1.2",
    "redux": "^5.0.1",
    "use-sync-external-store": "^1.4.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@ethersproject/abstract-signer": "^5.8.0",
    "@ethersproject/bignumber": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/constants": "^5.8.0",
    "@ethersproject/contracts": "^5.8.0",
    "@ethersproject/providers": "^5.8.0",
    "@ethersproject/wallet": "^5.8.0",
    "@microsoft/api-extractor": "^7.47.0",
    "@reduxjs/toolkit": "^2.2.5",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.2",
    "@types/prop-types": "^15.7.12",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "archiver": "^7.0.1",
    "assert": "^2.1.0",
    "autoprefixer": "^10.4.23",
    "codecov": "^3.8.3",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.7",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.12.0",
    "viem": "^2.45.1",
    "vitest": "^1.6.0"
  }
}
